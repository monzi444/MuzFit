<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/muz_surface_l0" />
            <stroke android:width="1dp" android:color="@color/muz_primary_lime" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/muz_surface_l0" />
            <stroke android:width="1dp" android:color="#80c5f701" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/muz_surface_l0" />
            <stroke android:width="1dp" android:color="@color/muz_on_surface_border" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</selector>
