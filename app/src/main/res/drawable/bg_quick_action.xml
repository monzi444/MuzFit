<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/muz_primary_lime_tint">
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/white" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <selector>
            <item android:state_pressed="true">
                <shape android:shape="rectangle">
                    <solid android:color="#33c5f701" />
                    <stroke android:width="1dp" android:color="#4dc5f701" />
                    <corners android:radius="18dp" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/muz_quick_action_bg" />
                    <stroke android:width="1dp" android:color="#1Affffff" />
                    <corners android:radius="18dp" />
                </shape>
            </item>
        </selector>
    </item>
</ripple>
