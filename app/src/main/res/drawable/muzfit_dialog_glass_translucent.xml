<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Subtle dim (15% dark) so the blurred backdrop stays visible through the dialog.
         A 1dp glass border keeps the dialog edges defined. -->
    <solid android:color="#26000000" />
    <corners android:radius="28dp" />
    <stroke
        android:width="1dp"
        android:color="@color/muz_glass_border" />
</shape>
