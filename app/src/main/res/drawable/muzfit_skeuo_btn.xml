<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed State (Concave) -->
    <item android:state_pressed="true">
        <layer-list>
            <!-- Background -->
            <item>
                <shape>
                    <corners android:radius="50dp" />
                    <solid android:color="@color/muz_container_l2" />
                </shape>
            </item>
            <!-- Top/Inside Shadow -->
            <item android:bottom="2dp">
                <shape>
                    <corners android:radius="50dp" />
                    <stroke android:width="3dp" android:color="@color/muz_skeuo_shadow_dark" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Normal State (Convex) -->
    <item>
        <layer-list>
            <!-- Bottom Thick Shadow -->
            <item android:top="4dp">
                <shape>
                    <corners android:radius="50dp" />
                    <solid android:color="@color/muz_skeuo_shadow_dark" />
                </shape>
            </item>
            <!-- Top Subtle Light Edge -->
            <item android:bottom="4dp">
                <shape>
                    <corners android:radius="50dp" />
                    <solid android:color="@color/muz_skeuo_shadow_light" />
                </shape>
            </item>
            <!-- Surface -->
            <item android:bottom="4dp" android:top="1.5dp">
                <shape>
                    <corners android:radius="50dp" />
                    <solid android:color="@color/muz_container_l2" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>