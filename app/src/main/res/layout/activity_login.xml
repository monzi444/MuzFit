<?xml version="1.0" encoding="utf-8"?>
<!--
  Login screen — full editorial redesign.
  Sections, top to bottom:
    1. Status-bar spacer (so the content starts below the system bar)
    2. Logo (brand mark)
    3. Hero (Welcome back / Sign in to MuzFit / subtitle)
    4. Glass card with email + password inputs + Login + Login with Google
    5. Bottom CTA: Create a new account
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/login_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/muz_surface_l0"
    android:fillViewport="true"
    tools:context=".ui.auth.LoginActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="56dp"
        android:paddingBottom="40dp">

        <!-- ============== LOGO ============== -->
        <ImageView
            android:layout_width="240dp"
            android:layout_height="120dp"
            android:contentDescription="MuzFit Logo"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_muzfit_all_var" />

        <!-- ============== HERO ============== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/syne_regular"
                android:letterSpacing="0.18"
                android:text="@string/login_hero_label"
                android:textAllCaps="true"
                android:textColor="@color/muz_primary_lime"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/syne_regular"
                android:text="@string/login_hero_title"
                android:textColor="@color/muz_on_surface"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/syne_regular"
                android:gravity="center"
                android:text="@string/login_hero_subtitle"
                android:textColor="@color/muz_on_surface_variant"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- ============== GLASS CARD: form ============== -->
        <com.google.android.material.card.MaterialCardView
            style="@style/MuzFit.Card.Glass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            app:cardCornerRadius="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <!-- Email -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/email_hint"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="@color/muz_primary_lime"
                    app:hintTextColor="@color/muz_primary_lime">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/email_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:autofillHints="emailAddress"
                        android:inputType="textEmailAddress"
                        android:singleLine="true"
                        android:textColor="@color/muz_on_surface"
                        android:textColorHint="@color/muz_on_surface_variant" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="@string/password_hint"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="@color/muz_primary_lime"
                    app:endIconMode="password_toggle"
                    app:hintTextColor="@color/muz_primary_lime">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/password_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:autofillHints="password"
                        android:inputType="textPassword"
                        android:singleLine="true"
                        android:textColor="@color/muz_on_surface"
                        android:textColorHint="@color/muz_on_surface_variant" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Primary: Login (lime) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/login_button"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="22dp"
                    android:backgroundTint="@color/muz_primary_lime"
                    android:fontFamily="@font/syne_regular"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/login_button"
                    android:textColor="@color/muz_surface_l0"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="14dp" />

                <!-- Divider with "or" -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/muz_glass_border" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="12dp"
                        android:fontFamily="@font/syne_regular"
                        android:letterSpacing="0.15"
                        android:text="OR"
                        android:textAllCaps="true"
                        android:textColor="@color/muz_on_surface_variant"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/muz_glass_border" />
                </LinearLayout>

                <!-- Secondary: Login with Google (outlined, official G icon) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/google_login_button"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="14dp"
                    android:fontFamily="@font/syne_regular"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/google_login_button"
                    android:textColor="@color/muz_on_surface"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="14dp"
                    app:icon="@drawable/ic_google_logo"
                    app:iconGravity="textStart"
                    app:iconPadding="10dp"
                    app:iconSize="18dp"
                    app:iconTint="@null"
                    app:strokeColor="@color/muz_glass_border" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ============== BOTTOM CTA: Create account ============== -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/create_account_button"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="@font/syne_regular"
            android:text="@string/create_account_button"
            android:textColor="@color/muz_primary_lime"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
