<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/muz_surface_l0"
    tools:context=".ui.MainActivity">

    <!-- Main Logo positioned at the top, increased size and further reduced vertical spacing -->
    <ImageView
        android:id="@+id/main_logo"
        android:layout_width="180dp"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="0dp"
        android:src="@drawable/logo_muzfit_2_var"
        android:scaleType="fitCenter"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="MuzFit" />

    <!-- Content container constrained BELOW the logo -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/main_logo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <FrameLayout
        android:id="@+id/quick_overlay_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <FrameLayout
        android:id="@+id/bottom_nav_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Blur layer — resized at runtime to match the actual pill width/height (see MainActivity).
             Initial size match_parent lets us not worry about scroll/insets; the post() call sets
             the exact dimensions to mirror the Compose pill. -->
        <eightbitlab.com.blurview.BlurView
            android:id="@+id/bottom_nav_blur"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_navbar_pill"
            android:clipToOutline="true" />

        <!-- Compose pill navigation — the BlurView mirrors this view's real size at runtime. -->
        <androidx.compose.ui.platform.ComposeView
            android:id="@+id/bottom_nav_compose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|bottom"
            android:layout_marginBottom="12dp" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>