<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/profile_setup_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/muz_surface_l0"
    tools:context=".ui.auth.ProfileSetupActivity">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="32dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="@string/profile_setup_title"
                android:textColor="@color/muz_on_surface"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/profile_setup_subtitle"
                android:textColor="@color/muz_on_surface_variant"
                android:textSize="15sp" />

            <com.google.android.material.card.MaterialCardView
                style="@style/MuzFit.Card.Glass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/profile_setup_avatar"
                        android:layout_width="104dp"
                        android:layout_height="104dp"
                        android:layout_gravity="center_horizontal"
                        android:padding="2dp"
                        android:src="@drawable/ic_launcher_background"
                        app:shapeAppearanceOverlay="@style/CircleAppearance"
                        app:strokeColor="@color/muz_glass_border"
                        app:strokeWidth="1.5dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/profile_setup_image_button"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="8dp"
                        android:text="@string/profile_image_button"
                        android:textColor="@color/muz_primary_lime" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/profile_name_hint"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/muz_primary_lime"
                        app:hintTextColor="@color/muz_primary_lime">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/profile_setup_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName|textCapWords"
                            android:singleLine="true"
                            android:textColor="@color/muz_on_surface" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:hint="@string/profile_weight_hint"
                            app:boxBackgroundMode="outline"
                            app:boxStrokeColor="@color/muz_primary_lime"
                            app:hintTextColor="@color/muz_primary_lime">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/profile_setup_weight"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:singleLine="true"
                                android:textColor="@color/muz_on_surface" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:hint="@string/profile_height_hint"
                            app:boxBackgroundMode="outline"
                            app:boxStrokeColor="@color/muz_primary_lime"
                            app:hintTextColor="@color/muz_primary_lime">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/profile_setup_height"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:singleLine="true"
                                android:textColor="@color/muz_on_surface" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <RadioGroup
                        android:id="@+id/profile_setup_gender"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/profile_setup_gender_male"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:checked="true"
                            android:text="@string/profile_gender_male"
                            android:textColor="@color/muz_on_surface" />

                        <RadioButton
                            android:id="@+id/profile_setup_gender_female"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/profile_gender_female"
                            android:textColor="@color/muz_on_surface" />
                    </RadioGroup>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/profile_kcal_hint"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/muz_primary_lime"
                        app:hintTextColor="@color/muz_primary_lime">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/profile_setup_kcal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:singleLine="true"
                            android:textColor="@color/muz_on_surface" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:hint="@string/profile_carbs_short_hint"
                            app:boxBackgroundMode="outline"
                            app:boxStrokeColor="@color/muz_primary_lime"
                            app:hintTextColor="@color/muz_primary_lime">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/profile_setup_carbs"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:singleLine="true"
                                android:textColor="@color/muz_on_surface" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="6dp"
                            android:layout_weight="1"
                            android:hint="@string/profile_protein_short_hint"
                            app:boxBackgroundMode="outline"
                            app:boxStrokeColor="@color/muz_primary_lime"
                            app:hintTextColor="@color/muz_primary_lime">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/profile_setup_protein"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:singleLine="true"
                                android:textColor="@color/muz_on_surface" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:hint="@string/profile_fat_short_hint"
                            app:boxBackgroundMode="outline"
                            app:boxStrokeColor="@color/muz_primary_lime"
                            app:hintTextColor="@color/muz_primary_lime">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/profile_setup_fat"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:singleLine="true"
                                android:textColor="@color/muz_on_surface" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/profile_setup_save"
                        style="@style/MuzFit.Button.Skeuo"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="20dp"
                        android:text="@string/profile_setup_save" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
