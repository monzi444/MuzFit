<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/muzfit_dialog_background"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            style="@style/MuzFit.Text.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/add_food_manual_title" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/food_name_hint"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/muz_primary_lime"
            app:hintTextColor="@color/muz_primary_lime">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTextFoodName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="@color/muz_on_surface" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/food_calories_hint"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/muz_primary_lime"
            app:hintTextColor="@color/muz_primary_lime">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTextCalories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textColor="@color/muz_on_surface" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/food_carbs_hint"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/muz_primary_lime"
            app:hintTextColor="@color/muz_primary_lime">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTextCarbs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textColor="@color/muz_on_surface" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/food_protein_hint"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/muz_primary_lime"
            app:hintTextColor="@color/muz_primary_lime">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTextProtein"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textColor="@color/muz_on_surface" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/food_fat_hint"
            app:boxBackgroundMode="outline"
            app:boxStrokeColor="@color/muz_primary_lime"
            app:hintTextColor="@color/muz_primary_lime">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTextFat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textColor="@color/muz_on_surface" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveManualFood"
            style="@style/MuzFit.Button.Skeuo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/save" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackManualFood"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/back"
            android:textColor="@color/muz_on_surface_variant" />

    </LinearLayout>
</ScrollView>
