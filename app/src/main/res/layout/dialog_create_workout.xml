<?xml version="1.0" encoding="utf-8"?>
<!--
  Dialog: search exercises (called from inside the manage-exercises dialog).
  Same look as dialog_choose_meal: BlurView backdrop + translucent glass content.
  Save / Cancel buttons are added programmatically via AlertDialog.Builder.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <eightbitlab.com.blurview.BlurView
        android:id="@+id/create_workout_blur"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_dialog_blur_rounded"
        android:clipToOutline="true" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/muzfit_dialog_glass_translucent"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header label uppercase -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/syne_regular"
            android:letterSpacing="0.12"
            android:text="@string/search_exercises_label"
            android:textColor="@color/muz_on_surface_variant"
            android:textSize="11sp"
            android:textStyle="bold" />

        <!-- Title display Syne. Kept @id/tilRoutineName container id for backward
             compat with the host code that does til.setVisibility(View.GONE). -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/syne_regular"
            android:text="@string/search_exercises"
            android:textColor="@color/muz_on_surface"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- tilRoutineName wrapper kept so the existing host code
             (til.setVisibility(View.GONE)) still works. -->
        <FrameLayout
            android:id="@+id/tilRoutineName"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/etRoutineName"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Section header: filter by body part -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_lucide_swap"
                app:tint="@color/muz_on_surface_variant" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:fontFamily="@font/syne_regular"
                android:text="Filter by body part"
                android:textColor="@color/muz_on_surface"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cgBodyParts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipChest"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/syne_regular"
                    android:text="Chest"
                    android:tag="chest" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBack"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/syne_regular"
                    android:text="Back"
                    android:tag="back" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipLegs"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/syne_regular"
                    android:text="Legs"
                    android:tag="upper legs" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipShoulders"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/syne_regular"
                    android:text="Shoulders"
                    android:tag="shoulders" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipArms"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/syne_regular"
                    android:text="Arms"
                    android:tag="upper arms" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCardio"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/syne_regular"
                    android:text="Cardio"
                    android:tag="cardio" />

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <!-- Section header: search exercise -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_lucide_search"
                app:tint="@color/muz_on_surface_variant" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:fontFamily="@font/syne_regular"
                android:text="@string/search_exercises"
                android:textColor="@color/muz_on_surface"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Search field with leading icon -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_glass"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingVertical="2dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_lucide_search"
                app:tint="@color/muz_on_surface_variant" />

            <EditText
                android:id="@+id/etSearchExercise"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@android:color/transparent"
                android:fontFamily="@font/syne_regular"
                android:hint="@string/search_hint"
                android:inputType="text"
                android:paddingVertical="14dp"
                android:singleLine="true"
                android:textColor="@color/muz_on_surface"
                android:textColorHint="@color/muz_on_surface_variant"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Results list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvExerciseResults"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="14dp"
            android:layout_weight="1"
            android:minHeight="200dp"
            android:background="@drawable/bg_input_glass"
            android:padding="6dp" />

        <!-- Selected count -->
        <TextView
            android:id="@+id/tvSelectedExercisesCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/syne_regular"
            android:text="@string/selected_exercises_count"
            android:textColor="@color/muz_on_surface_variant"
            android:textSize="12sp" />

        <!-- Action row: cancel (text) + save (lime, with check icon) — both
             live inside the glass card so the dialog reads as a single
             coherent surface rather than glass + system buttons. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelCreateWorkout"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:fontFamily="@font/syne_regular"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/cancel"
                android:textColor="@color/muz_on_surface_variant"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveCreateWorkout"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="2"
                android:layout_marginStart="6dp"
                android:backgroundTint="@color/muz_primary_lime"
                android:fontFamily="@font/syne_regular"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/save"
                android:textColor="@color/muz_surface_l0"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_lucide_check"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconSize="18dp"
                app:iconTint="@color/muz_surface_l0" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
