<?xml version="1.0" encoding="utf-8"?>
<!--
  Dialog: confirm deletion of a routine.
  Same look as dialog_choose_meal: BlurView backdrop + translucent glass content.
  Cancel + Delete both live inside the glass card.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- Blurred backdrop -->
    <eightbitlab.com.blurview.BlurView
        android:id="@+id/delete_confirm_blur"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_dialog_blur_rounded"
        android:clipToOutline="true" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/muzfit_dialog_glass_translucent"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header label uppercase -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/syne_regular"
            android:letterSpacing="0.12"
            android:text="@string/delete_confirm_label"
            android:textColor="@color/muz_on_surface_variant"
            android:textSize="11sp"
            android:textStyle="bold" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/syne_regular"
            android:text="@string/delete_confirm_title"
            android:textColor="@color/muz_on_surface"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Subtitle message (explains what will be deleted) -->
        <TextView
            android:id="@+id/tvDeleteConfirmMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/syne_regular"
            android:lineSpacingExtra="3dp"
            android:text="@string/delete_confirm_message"
            android:textColor="@color/muz_on_surface_variant"
            android:textSize="14sp" />

        <!-- Action row: cancel (text) + delete (red, with trash icon) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelDelete"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:fontFamily="@font/syne_regular"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/cancel"
                android:textColor="@color/muz_on_surface_variant"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmDelete"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="2"
                android:layout_marginStart="6dp"
                android:backgroundTint="@color/activity_low"
                android:fontFamily="@font/syne_regular"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/delete"
                android:textColor="@color/muz_surface_l0"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_lucide_trash"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconSize="18dp"
                app:iconTint="@color/muz_surface_l0" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
