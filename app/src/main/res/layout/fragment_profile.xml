<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/muz_surface_l0"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <LinearLayout
            android:id="@+id/ll_theme_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="Light Mode"
                android:src="@drawable/ic_sun"
                app:tint="@color/muz_on_surface_variant" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_theme"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                app:thumbTint="@color/muzfit_switch_thumb"
                app:trackTint="@color/muzfit_switch_track" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="Dark Mode"
                android:src="@drawable/ic_moon"
                app:tint="@color/muz_on_surface_variant" />
        </LinearLayout>

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_avatar"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="32dp"
            android:padding="2dp"
            android:src="@drawable/ic_launcher_background"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/CircleAppearance"
            app:strokeColor="@color/muz_glass_border"
            app:strokeWidth="1.5dp" />

        <TextView
            android:id="@+id/tv_nome_utente"
            style="@style/MuzFit.Text.Display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Nome Utente"
            android:textSize="28sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/iv_avatar" />

        <TextView
            android:id="@+id/tv_email_utente"
            style="@style/MuzFit.Text.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="utente@example.com"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_nome_utente" />

        <!-- Physique Card (Glassmorphism) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_physique"
            style="@style/MuzFit.Card.Glass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            app:layout_constraintTop_toBottomOf="@+id/tv_email_utente">

            <LinearLayout
                android:id="@+id/ll_info_fisiche"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="24dp">

                <LinearLayout style="@style/VerticalStatBox">
                    <TextView
                        style="@style/MuzFit.Text.Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Peso" />

                    <TextView
                        android:id="@+id/tv_peso"
                        style="@style/MuzFit.Text.Display"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- kg"
                        android:textSize="20sp" />
                </LinearLayout>

                <LinearLayout style="@style/VerticalStatBox">
                    <TextView
                        style="@style/MuzFit.Text.Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Altezza" />

                    <TextView
                        android:id="@+id/tv_altezza"
                        style="@style/MuzFit.Text.Display"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- cm"
                        android:textSize="20sp" />
                </LinearLayout>

                <LinearLayout style="@style/VerticalStatBox">
                    <TextView
                        style="@style/MuzFit.Text.Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_gender_label" />

                    <TextView
                        android:id="@+id/tv_eta"
                        style="@style/MuzFit.Text.Display"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- anni"
                        android:textSize="20sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_modifica_profilo"
            style="@style/MuzFit.Button.Skeuo"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="48dp"
            android:text="Modifica Profilo"
            app:layout_constraintTop_toBottomOf="@+id/card_physique" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_obiettivi"
            style="@style/MuzFit.Button.Skeuo"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="16dp"
            android:text="Imposta Obiettivi"
            app:layout_constraintTop_toBottomOf="@+id/btn_modifica_profilo" />

        <!-- Goals Card (Glassmorphism) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_goals"
            style="@style/MuzFit.Card.Glass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="64dp"
            app:layout_constraintTop_toBottomOf="@+id/btn_obiettivi">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    style="@style/MuzFit.Text.Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kcal Quotidiane" />

                <TextView
                    android:id="@+id/tv_obiettivo_kcal"
                    style="@style/MuzFit.Text.Display"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OB = 2000"
                    android:textSize="24sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:background="@color/muz_glass_border" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_carbo"
                        style="@style/HorizontalStatText"
                        android:text="Carbo\n-- g" />

                    <TextView
                        android:id="@+id/tv_proteine"
                        style="@style/HorizontalStatText"
                        android:text="Proteine\n-- g" />

                    <TextView
                        android:id="@+id/tv_grassi"
                        style="@style/HorizontalStatText"
                        android:text="Grassi\n-- g" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_logout"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:text="@string/logout_button"
            android:textColor="@color/activity_low"
            app:layout_constraintTop_toBottomOf="@+id/card_goals"
            app:strokeColor="@color/activity_low" />

        <!-- Dynamic Spacer to prevent overlap with Floating Navbar -->
        <View
            android:id="@+id/nav_spacer"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            app:layout_constraintTop_toBottomOf="@+id/btn_logout" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
