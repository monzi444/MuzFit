<?xml version="1.0" encoding="utf-8"?>
<!--
  Reusable "quick action" card used by fragment_quick.xml.
  Each card has:
    - a circle icon container (lime tinted)
    - the action label (12sp Syne, bold)
    - the action subtitle (10sp, dim, optional)
  The card background is the same `bg_quick_action_card` drawable
  (rounded glass pill with ripple + pressed state).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_quick_action_card"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="10dp"
    android:paddingTop="18dp"
    android:paddingBottom="16dp">

    <!-- Icon disc: lime circle with the Lucide icon on top -->
    <FrameLayout
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_quick_action_icon">

        <ImageView
            android:id="@+id/quick_action_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:src="@drawable/ic_lucide_utensils"
            app:tint="@color/muz_surface_l0" />
    </FrameLayout>

    <!-- Action label -->
    <TextView
        android:id="@+id/quick_action_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/syne_regular"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="Action"
        android:textColor="@color/muz_on_surface"
        android:textSize="13sp"
        android:textStyle="bold" />

</LinearLayout>
