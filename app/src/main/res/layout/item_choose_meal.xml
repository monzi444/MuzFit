<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_meal_list_item"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="14dp"
    android:paddingEnd="16dp"
    android:paddingVertical="12dp">

    <ImageView
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_lucide_utensils"
        app:tint="@color/muz_primary_lime"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

    <TextView
        android:id="@+id/mealItemName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="14dp"
        android:fontFamily="@font/syne_regular"
        android:textColor="@color/muz_on_surface"
        android:textSize="14sp"
        android:fontWeight="500" />

    <TextView
        android:id="@+id/mealItemKcal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:textColor="@color/muz_on_surface_variant"
        android:textSize="12sp" />

</LinearLayout>
