<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/MuzFit.Card.Glass"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvSetNumber"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="1"
            android:gravity="center"
            android:textStyle="bold"
            android:textColor="@color/muz_surface_l0"
            android:background="@drawable/muzfit_category_card_bg"
            android:backgroundTint="@color/muz_primary_lime" />

        <TextView
            android:id="@+id/tvWeightSelector"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="24dp"
            android:background="@drawable/muzfit_input_bg"
            android:gravity="center"
            android:text="20.0 kg"
            android:textColor="@color/muz_on_surface"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tvRepsSelector"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:background="@drawable/muzfit_input_bg"
            android:gravity="center"
            android:text="10 reps"
            android:textColor="@color/muz_on_surface"
            android:clickable="true"
            android:focusable="true" />

        <CheckBox
            android:id="@+id/cbSetDone"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:buttonTint="@color/muz_primary_lime"
            android:background="@null"
            android:gravity="center" />

        <ImageButton
            android:id="@+id/btnDeleteSet"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/muz_on_surface_variant"
            android:contentDescription="Delete set" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>