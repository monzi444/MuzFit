<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/muz_surface_l0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnToggleExecution"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:text="@string/see_execution"
            android:textColor="@color/muz_primary_lime"
            app:strokeColor="@color/muz_primary_lime" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvSessionExerciseGif"
            style="@style/MuzFit.Card.Glass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/ivSessionExerciseGif"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:scaleType="fitCenter"
                android:contentDescription="Exercise demonstration" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            style="@style/MuzFit.Text.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/instructions_label"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            style="@style/MuzFit.Card.Glass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvSessionInstructions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/muz_on_surface"
                android:padding="16dp"
                android:lineSpacingMultiplier="1.2" />
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
